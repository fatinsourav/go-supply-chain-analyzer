# Go Module Index
MODULE_INDEX_URL=https://index.golang.org/index
PROXY_URL=https://proxy.golang.org

# Data Collection
MAX_MODULES=1000
BATCH_SIZE=100

# go.mod dependency fetch: 0 = fetch all modules (full dependency graph).
# A positive value truncates to the first N modules (faster, partial graph).
GOMOD_FETCH_LIMIT=0

# Pattern Detection Thresholds
LEVENSHTEIN_THRESHOLD=2
SIMILARITY_THRESHOLD=0.8
UPDATE_FREQUENCY_THRESHOLD=3
# Concentration: flag modules depended upon by >= N other modules.
# Set to 50 based on the full-graph dependent-count distribution; analysis
# focuses on the high-count head (top ecosystem chokepoints).
CONCENTRATION_THRESHOLD=50

# Storage
DB_PATH=./data/output/analyzer.db

# Output
CSV_OUTPUT_PATH=./data/output
JSON_OUTPUT_PATH=./data/output

# Logging
LOG_LEVEL=info
